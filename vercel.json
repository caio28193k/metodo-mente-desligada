{
  "rewrites": [
    {
      "source": "/",
      "destination": "/metodo-mente-desligada.html"
    },
    {
      "source": "/obrigado",
      "destination": "/obrigado.html"
    },
    {
      "source": "/programa-21-noites",
      "destination": "/programa-21-noites.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
